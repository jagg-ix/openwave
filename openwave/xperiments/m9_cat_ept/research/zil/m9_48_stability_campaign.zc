MODULE openwave.m9.stability_campaign.

component:physlib_convergence_in_distribution#kind@entity:component.
component:physlib_convergence_in_distribution#provided_by@api:MeasureTheory.TendstoInDistribution.
component:physlib_ae_limit_bridge#kind@entity:component.
component:physlib_ae_limit_bridge#provided_by@api:MeasureTheory.tendstoInDistribution_of_ae_tendsto.
component:physlib_probability_measure_topology#kind@entity:component.
component:physlib_probability_measure_topology#provided_by@api:ProbabilityMeasure.
component:physlib_bounded_exponential#kind@entity:component.
component:physlib_bounded_exponential#provided_by@api:NormedSpace.exp.

claim:finite_grid_long_horizon_campaign#kind@entity:simulation.
claim:finite_grid_long_horizon_campaign#uses@component:physlib_convergence_in_distribution.
claim:finite_grid_long_horizon_campaign#uses@component:physlib_ae_limit_bridge.
claim:finite_grid_long_horizon_campaign#uses@component:physlib_probability_measure_topology.
claim:finite_grid_long_horizon_campaign#uses@component:physlib_bounded_exponential.
claim:finite_grid_long_horizon_campaign#implemented_by@python:openwave.m9.stability_campaign_3d.

claim:continuum_orbital_stability#kind@entity:theorem.
claim:continuum_orbital_stability#target_state@state:open.
claim:continuum_orbital_stability#requires@claim:finite_grid_long_horizon_campaign.

QUERY reused_components:
FIND ?claim ?component WHERE ?claim#uses@?component.

QUERY open_targets:
FIND ?claim WHERE ?claim#target_state@state:open.

MODULE openwave.m9.unified_convergence.
claim:m9.56.nested_grid_error#target_state@state:closed.
claim:m9.56.ledger_convergence#target_state@state:closed.
claim:m9.56.temperature_entropy_controls#target_state@state:closed.
claim:continuum_solution_constructed#target_state@state:open.
claim:continuum_convergence_theorem#target_state@state:open.
QUERY convergence_status:
FIND ?claim ?state WHERE ?claim#target_state@?state.

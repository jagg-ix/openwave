# Heavy REGENERABLE npz caches (>1MB), kept local, regen from the scripts (repro table in m5_roadmap.md).
# Relocated to research/data/ by the 2026-07-02 sandbox consolidation (were sandbox_v8/, sandbox_vn/).
# seed refs + precision twins (regen: <CB env> python m5_8_2cb_taichi_constrained.py <ref|ti cpu f64|...>)
openwave/xperiments/m5_liquid_crystal/research/data/_m5_8_2cb_ref*.npz
openwave/xperiments/m5_liquid_crystal/research/data/_m5_8_2cb_ti_*.npz
openwave/xperiments/m5_liquid_crystal/research/data/*.npz.bak
# Track C tabulations (regen: python m5_8_2f*.py all, one-time ~110s each)
openwave/xperiments/m5_liquid_crystal/research/data/_m5_8_2f_tables.npz
openwave/xperiments/m5_liquid_crystal/research/data/_m5_8_2f2_tables.npz
openwave/xperiments/m5_liquid_crystal/research/data/_m5_8_2f3_kin.npz
# settled configs (regen: m5_8_2g settle / m5_8_2o settle)
openwave/xperiments/m5_liquid_crystal/research/data/_m5_8_2g_settled.npz
openwave/xperiments/m5_liquid_crystal/research/data/_m5_8_2o_settled.npz

# All model theory/ folders hold third-party copyrighted papers (PDF/docx/etc.), kept LOCAL only
# (publisher PDFs, author docs , not redistributable on a public repo; the m7 corpus alone is ~700 MB).
# Decision 2026-06-30: untrack going forward (files remain in pre-existing history; no rewrite).
# Our own research notes (*.md) and the per-folder _CITATIONS.md manifests stay tracked.
# (`**/` matches zero or more dirs, so these cover both theory/ root and any subfolders.)
openwave/xperiments/*/theory/**/*.pdf
openwave/xperiments/*/theory/**/*.docx
openwave/xperiments/*/theory/**/*.doc
openwave/xperiments/*/theory/**/*.epub
openwave/xperiments/*/theory/**/*.ppt
openwave/xperiments/*/theory/**/*.pptx
openwave/xperiments/*/theory/**/*.djvu
openwave/xperiments/*/theory/**/*.tex
openwave/xperiments/*/theory/**/*.bib
# m7 electron_beltrami/ is a pure local corpus , ignore the whole folder (incl. any non-doc strays).
# Its manifest lives one level up at theory/_CITATIONS.md (a *.md, tracked by default).
openwave/xperiments/m7_hydroboros/theory/electron_beltrami/*

# Author-conversation records (call transcripts, message threads) are LOCAL-ONLY for author
# privacy, whatever the format: ignore the whole folder in every model's theory/.
# Naming convention: <taskID or phaseID>_convo.<ext> (e.g. m7_phase1_convo.pdf).
openwave/xperiments/*/theory/author_convos/

# Agent resume checkpoints (session-local in-flight state for any Mx model task; not research
# artifacts, never tracked). Findings live in the tracked tasks/ + data/ + plots/ instead.
openwave/xperiments/*/research/checkpoints/
